{
    "name": "llama-cpp-node-api",
    "version": "0.10.0",
    "description": "Node.js native addon for llama.cpp — direct in-process inference",
    "main": "js/index.js",
    "types": "js/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sir-ingvarr/llama-cpp-node-api.git"
    },
    "license": "MIT",
    "keywords": [
        "llama",
        "llm",
        "inference",
        "native-addon",
        "gguf",
        "electron"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "preinstall": "test -d .git && git submodule update --init --recursive || true",
        "build": "cmake-js compile",
        "build:debug": "cmake-js compile --debug",
        "build:cuda": "cmake-js compile -- -DGGML_CUDA=ON",
        "build:cpu": "cmake-js compile -- -DGGML_METAL=OFF",
        "build:root": "cmake-js rebuild",
        "rebuild": "cmake-js rebuild",
        "build:arm64": "cmake-js compile --arch arm64",
        "build:x64": "cmake-js compile --arch x64",
        "update:llama": "git submodule update --remote vendor/llama.cpp"
    },
    "cmake-js": {
        "runtime": "electron",
        "runtimeVersion": "35.0.0",
        "silent": false
    },
    "files": [
        "js/",
        "LICENSE",
        "README.md"
    ],
    "dependencies": {},
    "devDependencies": {
        "cmake-js": "^8.0.0",
        "node-addon-api": "^8.3.0"
    },
    "optionalDependencies": {
        "@llama-cpp-node-api/darwin-arm64": "0.9.1",
        "@llama-cpp-node-api/darwin-x64": "0.9.1",
        "@llama-cpp-node-api/linux-x64": "0.9.1",
        "@llama-cpp-node-api/win32-x64": "0.9.1"
    }
}
