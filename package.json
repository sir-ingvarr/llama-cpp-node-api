{
    "name": "llama-node",
    "version": "0.9.0",
    "description": "Node.js native addon for llama.cpp — direct in-process inference",
    "main": "js/index.js",
    "types": "js/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sir-ingvarr/node-llama-cpp.git"
    },
    "license": "MIT",
    "keywords": [
        "llama",
        "llm",
        "inference",
        "native-addon",
        "gguf",
        "electron"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "preinstall": "git submodule update --init --recursive",
        "install": "prebuild-install -r napi || cmake-js compile",
        "build": "cmake-js compile",
        "build:debug": "cmake-js compile --debug",
        "build:cuda": "cmake-js compile -- -DGGML_CUDA=ON",
        "build:cpu": "cmake-js compile -- -DGGML_METAL=OFF",
        "build:root": "cmake-js rebuild",
        "rebuild": "cmake-js rebuild",
        "build:arm64": "cmake-js compile --arch arm64",
        "build:x64": "cmake-js compile --arch x64",
        "update:llama": "git submodule update --remote vendor/llama.cpp"
    },
    "cmake-js": {
        "runtime": "electron",
        "runtimeVersion": "35.0.0",
        "silent": false
    },
    "binary": {
        "module_name": "llama_node",
        "module_path": "build/Release",
        "napi_versions": [8]
    },
    "files": [
        "js/",
        "src/",
        "vendor/",
        "CMakeLists.txt",
        "package.json"
    ],
    "dependencies": {
        "cmake-js": "^8.0.0",
        "node-addon-api": "^8.3.0",
        "prebuild-install": "^7.1.3"
    }
}
